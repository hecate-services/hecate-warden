# hecate-warden drop-in configuration.  cp .env.example .env  and fill in.
# Full reference: docs/INTEGRATION.md#environment-reference

# --- who + where (carried on every fact) ---
# WHO operates this warden — your org id. Attribution in the commons.
HECATE_WARDEN_TENANT_ID=acme-corp
# WHERE this warden runs — a box/service name. One tenant, many labels.
HECATE_WARDEN_LABEL=web-01

# --- the commons you join (given to you; not secrets) ---
# The 64-hex realm (topic scope everyone in this commons shares).
HECATE_REALM=074acb6cb190d8ef79fdbdd8e8e76d53f6292c181fd23f4d3998560f9a94e8e3
# A station URL to reach the mesh.
MACULA_STATION_SEEDS=https://station-de-frankfurt.macula.io:4433

# --- sensing-only by default; the tarpit is opt-in ---
# [] opens NO ports (zero added attack surface). To enable the tarpit, open the
# decoy ports in your firewall FIRST, then set e.g.  [2222,2323]
HECATE_WARDEN_TARPIT_PORTS=[]
HECATE_WARDEN_MAX_CONNS=65536

# --- your host's auth log (RHEL / Amazon Linux: /var/log/secure) ---
HECATE_WARDEN_AUTH_LOG_HOST=/var/log/auth.log
