%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_warden
%%
%% Layer-2 hecate-om service: the deceptive threshold guard that runs as a
%% sidecar to macula-station on the PUBLIC boxes. It senses attacks and wastes
%% attackers' time, and it publishes what it sees onto the mesh.
%%
%% STORELESS BY DESIGN. This runs on the most-attacked machines in the fleet, so
%% it holds the least: no reckon-db, no cognition, no LLM key, and a minimal mesh
%% identity that can only publish threat facts. Popped, an attacker gains a
%% tarpit controller for one box. The durable evidence chain lives in
%% hecate-spartan, on infrastructure that is not under attack.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% The shared L2 substrate: mesh SDK + realm identity + capabilities +
    %% health. No store_id/0 + data_dir/0 here, so hecate_om:boot/1 wires the
    %% mesh but starts NO reckon-db store — this is a producer-only service.
    {hecate_om, "~> 0.6"}
]}.

{project_plugins, [rebar3_ex_doc, rebar3_lint]}.

%% Elvis. The org runs a focused ruleset that targets structural smells rather
%% than the full erl_files set: deep nesting (HARD limit, one meaningful level),
%% nested try/catch, and if-expressions (we pattern-match clauses instead). Run
%% via `rebar3 lint`.
{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [
        #{files => ["apps/*/src/**/*.erl"], ruleset => macula_min}
    ]}
]}.

{relx, [
    {release, {hecate_warden, "0.1.0"}, [hecate_warden, sasl]},
    {sys_config_src, "config/sys.config.src"},
    {vm_args_src,    "config/vm.args.src"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod},
                    {include_src, false},
                    {include_erts, true},
                    {debug_info, strip}]}]}
]}.

{dialyzer, [
    {warnings, [no_unknown]},
    {exclude_apps, [
        macula, macula_envy, macula_mdns,
        reckon_db, reckon_evoq, reckon_gater, evoq,
        khepri, ra, horus, aten, seshat, gen_batch_server,
        gproc, msgpack, cowboy, ranch, jsx
    ]}
]}.

{shell, [{apps, [hecate_warden]}]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-services/hecate-warden">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE"]},
    {main, "README.md"}
]}.
